# Copy this file to backend/.env and fill in real values.
# NEVER commit backend/.env — it is in .gitignore.

OPENAI_API_KEY=sk-proj-replace-with-your-openai-key
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io:6333
QDRANT_API_KEY=replace-with-your-qdrant-api-key
COHERE_API_KEY=replace-with-your-cohere-api-key

# Comma-separated list of origins allowed by CORS.
# Local dev default: http://localhost:3000
# When deployed, add your deployed frontend URL, e.g.
#   https://eces-rag-system-frontend.onrender.com
ALLOWED_ORIGINS=http://localhost:3000
